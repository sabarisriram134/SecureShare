<?xml version="1.0" encoding="UTF-8"?>
<svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Background circle -->
  <circle cx="32" cy="32" r="30" fill="#4F46E5" stroke="#4338CA" stroke-width="2"/>
  
  <!-- Lock icon -->
  <g transform="translate(16, 18)">
    <!-- Lock body -->
    <rect x="4" y="10" width="24" height="18" rx="2" fill="white" stroke="white" stroke-width="1"/>
    
    <!-- Lock shackle -->
    <path d="M 8 10 Q 8 2 16 2 Q 24 2 24 10" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
    
    <!-- Keyhole -->
    <circle cx="16" cy="19" r="1.5" fill="#4F46E5"/>
  </g>
  
  <!-- Share icon dots -->
  <circle cx="48" cy="20" r="3" fill="#FCD34D"/>
  <circle cx="48" cy="44" r="3" fill="#FCD34D"/>
  <circle cx="20" cy="44" r="3" fill="#FCD34D"/>
  
  <!-- Connection lines -->
  <line x1="46" y1="23" x2="22" y2="42" stroke="#FCD34D" stroke-width="1.5" stroke-opacity="0.6"/>
  <line x1="46" y1="41" x2="22" y2="46" stroke="#FCD34D" stroke-width="1.5" stroke-opacity="0.6"/>
</svg>
